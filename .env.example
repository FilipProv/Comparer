# Skopiuj ten plik do .env i uzupełnij prawdziwymi wartościami
# cp .env.example .env

# MongoDB Atlas — baza danych w chmurze
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?appName=AppName
MONGO_DB=comparer

# Groq — OCR / AI import wycen (darmowy: 7000 req/dzień)
# Klucz: https://console.groq.com → API Keys → Create API Key
GROQ_API_KEY=

# Google Gemini — alternatywa (darmowy: 1500 req/dzień)
# Klucz: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenAI GPT-4o — alternatywa (płatna)
OPENAI_API_KEY=

# Pipedrive CRM
PIPEDRIVE_TOKEN=
PIPEDRIVE_DOMAIN=

# IMAP (read-only) — automatyczne pobieranie wycen ze skrzynki
IMAP_HOST=mail.example.com
IMAP_PORT=993
IMAP_USER=sales@example.com
IMAP_PASS=
IMAP_FOLDER=INBOX
IMAP_USE_SSL=true

# SMTP — wysyłka zamówień
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
